# 🚀 Пример .env для ПРОДАКШЕНА (gustaw.ru)
# 
# ⚠️ ВАЖНО: Это только ПРИМЕР!
# Скопируйте и отредактируйте на своём продакшен сервере

# ========================================
# DATABASE (оставьте свой существующий!)
# ========================================
DATABASE_URL="postgresql://ваш_продакшен_юзер:пароль@хост:5432/ваша_бд"

# ========================================
# NEXTAUTH (НОВОЕ - обязательно!)
# ========================================
NEXTAUTH_URL="https://gustaw.ru"
NEXTAUTH_SECRET="FmnFGdttgGdCRmt7/ivQ08VdoB26xy7hU+pmuMkrDZs="

# ========================================
# SESSION (оставьте свой существующий!)
# ========================================
SESSION_SECRET="ваш-существующий-session-secret"

# ========================================
# GOOGLE OAUTH (НОВОЕ)
# ========================================
GOOGLE_CLIENT_ID="ваш-реальный-client-id-из-google-console"
GOOGLE_CLIENT_SECRET="ваш-реальный-client-secret-из-google-console"

# ========================================
# CLOUDINARY (оставьте свои существующие!)
# ========================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="dhnzp0qqr"
CLOUDINARY_URL=cloudinary://281893215438352:PpXI18mPXEmlCHycS61y3KNTH3g@dhnzp0qqr
CLOUDINARY_API_KEY=281893215438352
CLOUDINARY_API_SECRET=PpXI18mPXEmlCHycS61y3KNTH3g

# ========================================
# ЗАМЕТКИ
# ========================================
# 
# 1. DATABASE_URL:
#    - Если используете Docker на том же сервере:
#      postgresql://gustaw:gustawpassword@localhost:5432/gustawdb
#    - Если используете внешнюю БД:
#      postgresql://user:password@external-host:5432/dbname
#
# 2. NEXTAUTH_SECRET:
#    - Должен быть ДРУГИМ в продакшене (не такой как в dev)
#    - Сгенерировать новый: openssl rand -base64 32
#
# 3. NEXTAUTH_URL:
#    - Должен быть https://gustaw.ru (не localhost!)
#
# 4. Google OAuth credentials:
#    - Те же самые как в dev (можно использовать одни credentials)
#    - Но не забудьте добавить redirect URI в Google Console:
#      https://gustaw.ru/api/auth/callback/google

